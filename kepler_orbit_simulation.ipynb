import numpy as np
import matplotlib.pyplot as plt
def f(t,U):
    x=U[0]
    y=U[1]
    vx=U[2]
    vy=U[3]
    ax=-x/(x**2+y**2)**(3/2)
    ay=-y/(x**2+y**2)**(3/2)
    return np.array([ax,ay])
U=np.array([1,0,0,1])
t=0
def E_C(t,U_init, f):
    steps=580
    h=0.01
    U = U_init.copy()
    t_hist=[t]
    x_hist=[U[0]]
    y_hist=[U[1]]
    vx_hist=[U[2]]
    vy_hist=[U[3]]
    for i in range(steps):
        dev=f(t,U)
        U[2]=U[2]+h*dev[0]
        U[3]=U[3]+h*dev[1]
        U[0]=U[0]+h*U[2]
        U[1]=U[1]+h*U[3]
        t+=h
        t_hist.append(t)
        x_hist.append(U[0])
        y_hist.append(U[1])
        vx_hist.append(U[2])
        vy_hist.append(U[3])
    return t_hist,x_hist,y_hist,vx_hist,vy_hist
# 1. ΕΠΑΝΑΦΟΡΑ ΤΩΝ ΑΡΧΙΚΩΝ ΤΙΜΩΝ (Πριν από κάθε εκτέλεση)
U = np.array([0.8906, 0.34, 0.578, 0.849]) 
t = 0

# 2. ΚΛΗΣΗ ΤΗΣ ΣΥΝΑΡΤΗΣΗΣ
s0, s1, s2, s3, s4 = E_C(t, U, f)    

# 3. ΣΧΕΔΙΑΣΗ
plt.figure(figsize=(15, 8))

# Αριστερό γράφημα: Τροχιά
plt.subplot(1, 2, 1)
plt.plot(s1, s2, label="Τροχιά Δορυφόρου")
plt.axis('equal') # <-- ΑΥΤΟ ΕΙΝΑΙ ΣΗΜΑΝΤΙΚΟ για να φανεί ο κύκλος σωστά!
plt.grid(True)
# Προσθήκη του Ήλιου στο (0,0)
sun = plt.Circle((0, 0), 0.05, color='yellow', label='Ήλιος')
plt.gca().add_artist(sun)

# Προσθήκη της Γης στο τέλος της τροχιάς
# Χρησιμοποιούμε τις τελευταίες τιμές x, y από τα x_hist, y_hist
earth_x = s1[-1]
earth_y = s2[-1]
earth = plt.Circle((earth_x, earth_y), 0.02, color='blue', label='Γη')
plt.gca().add_artist(earth)

plt.legend()
plt.legend()

# Δεξί γράφημα: Ακτίνα
s1_arr = np.array(s1)
s2_arr = np.array(s2)
r = np.sqrt(s1_arr**2 + s2_arr**2)

plt.subplot(1, 2, 2)
plt.plot(s0, r, label="Ακτίνα r", color="orange")
plt.grid(True)
plt.legend()

plt.tight_layout()
plt.show()
