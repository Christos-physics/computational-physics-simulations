vx3, vy3 = -2*vx1,   -2*vy1     # Εξισορρόπηση ορμής
# Το τελικό σου διάνυσμα U
U = np.array([x1, y1, x2, y2, x3, y3, vx1, vy1, vx2, vy2, vx3, vy3])
t = 0
s0, s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12 = rk4(t, U, f)
